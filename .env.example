# ─────────────────────────────────────────────────────────────
# ClawLite — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# NUNCA commitees .env al repositorio (.gitignore ya lo bloquea).
# Las claves API se migran automáticamente al vault cifrado en el
# primer arranque (quedan protegidas en reposo, no en texto plano).
#
# CONTRATO para clawlite/setup.py: el comentario de UNA línea inmediatamente
# anterior a cada "CLAVE=" se usa como pista interactiva de dónde conseguir
# esa clave. Si editás este archivo, mantené un único comentario de texto
# justo arriba de cada clave obligatoria (no líneas en blanco ni separadores
# decorativos entre el comentario y la clave).
# ─────────────────────────────────────────────────────────────

# ── Telegram (obligatorio) ───────────────────────────────────
# Crea tu bot y obtén el token en @BotFather
TELEGRAM_BOT_TOKEN=
# Tu ID numérico de Telegram (mandale un mensaje a @userinfobot para
# conseguirlo en 10 segundos). Sin esto, cualquiera que llegue a hablarle
# al bot (username descubierto, un enlace, un grupo, una invitación) podría
# usarlo -- este valor restringe el acceso solo a vos.
TELEGRAM_OWNER_ID=

# ── Búsqueda web — Tavily (obligatorio para research) ────────
# Plan gratuito suficiente: https://tavily.com
TAVILY_API_KEY=

# ── Modelo de lenguaje — elige tu nivel ──────────────────────
# Nivel 1 (móvil/sin PC potente): usa Groq — gratis, sin tarjeta.
#   Pon tu GROQ_API_KEY y LLM_PROVIDER=groq.
# Nivel 2 (local-first/privacidad): usa Ollama — todo en tu máquina.
#   Instala Ollama, deja LLM_PROVIDER=ollama (default).
# Nivel 3 (avanzado): configura Anthropic/OpenAI con tus claves.
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Overrides opcionales de modelo local POR TAREA (vacío = usa OLLAMA_MODEL).
# Útil si tienes VRAM de sobra; con 8GB deja todo vacío (modelo único).
OLLAMA_MODEL_CODING=
OLLAMA_MODEL_PLANNER=
OLLAMA_MODEL_FACTCHECK=
OLLAMA_MODEL_MEMORY=
OLLAMA_MODEL_STRUCTURED=
OLLAMA_MODEL_CONVERSATIONAL=

# Nube (opcionales — la cascada cae al siguiente si uno falla)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cascadas por tarea (avanzado; defaults sensatos — no tocar salvo que sepas)
# Formato: proveedores separados por coma, en orden de preferencia.
#LLM_TASK_CONVERSATIONAL=
#LLM_TASK_CODING=
#LLM_TASK_PLANNER=
#LLM_TASK_FACTCHECK=

# ── Datos y seguridad ────────────────────────────────────────
DB_PATH=./data/clawlite.db
# Sandbox de ejecución de código: strict | permissive (nunca off)
SANDBOX_MODE=strict

# ── Jobs asíncronos ──────────────────────────────────────────
MAX_CONCURRENT_JOBS=2

# ── Servidor MCP (opcional — expone 9 tools a clientes MCP) ──
MCP_ENABLED=false
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_DEFAULT_USER_ID=
MCP_TOKEN=

# ── Daily Brief (resumen matutino) ───────────────────────────
BRIEF_ENABLED=false
BRIEF_HOUR=8
BRIEF_TIMEZONE=UTC

# ── Logs ─────────────────────────────────────────────────────
# INFO para uso normal; DEBUG activa trazas de diagnóstico (planner, memoria)
LOG_LEVEL=INFO
